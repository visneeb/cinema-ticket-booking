#------------FRONTEND------------
# Firebase
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

#------------BACKEND------------

# RabbitMQ credentials (used by both docker-compose and local dev)
RABBITMQ_USER=
RABBITMQ_PASS=
# RABBITMQ_URL is only needed for LOCAL development (outside Docker).
# When running via Docker, docker-compose sets the correct internal URL automatically.
# RABBITMQ_URL=amqp://<username>:<password>@localhost:5672/

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# CORS — comma-separated list of allowed browser origins.
# For Docker (local):      leave blank (defaults to http://localhost:3000)
# For a real domain:       CORS_ORIGINS=https://yourdomain.com
# For local dev + Docker:  CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ORIGINS=

#  Notes
# 1. Copy this file to .env and fill in the values above.
# 2. Place firebase-service-account.json at the repo root (mount path for Docker).
# 3. In MongoDB Atlas → Network Access, allow 0.0.0.0/0 (or your host IP).
# 4. In Firebase Console → Authentication → Authorized Domains, add your domain.
# Get Firebase config from: Firebase Console → Project Settings → Your Apps
# Get Atlas URI from: Atlas → your cluster → Connect → Drivers